        <mxCell id="xhyheTG0EHDTFoFn0KrG-1" value="&lt;div&gt;&amp;nbsp; OSThread* osthread = &lt;span style=&quot;background-color: rgb(204, 153, 255);&quot;&gt;new OSThread&lt;/span&gt;(NULL, NULL);&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;&quot;&gt;// Store pthread info into the OSThread&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;&quot;&gt;&amp;nbsp;osthread-&amp;gt;set_thread_id(os::Linux::gettid());&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;&quot;&gt;&amp;nbsp; osthread-&amp;gt;set_pthread_id(::pthread_self());&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;span style=&quot;&quot;&gt;&amp;nbsp;// Initial thread state is RUNNABLE&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; osthread-&amp;gt;set_state(&lt;span style=&quot;background-color: rgb(204, 153, 255);&quot;&gt;RUNNABLE&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: rgb(229, 204, 255);&quot;&gt;&amp;nbsp; thread-&amp;gt;set_osthread(osthread);&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;labelBackgroundColor=none;fontSize=15;fontColor=#000000;strokeWidth=1;fillColor=default;align=left;" parent="xhyheTG0EHDTFoFn0KrG-7" vertex="1">
