        <mxCell id="xhyheTG0EHDTFoFn0KrG-41" value="&lt;div&gt;// 会调用set_native_thread_name用于设置线程名称，完成后，调试窗口的线程名称会显示该名称&lt;/div&gt;&lt;div&gt;&amp;nbsp;this-&amp;gt;initialize_named_thread();&lt;/div&gt;&lt;div&gt;&amp;nbsp; this-&amp;gt;record_stack_base_and_size();&lt;/div&gt;&lt;div&gt;this-&amp;gt;set_active_handles(JNIHandleBlock::allocate_block());&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp;MutexLocker ml(Notify_lock);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &lt;span style=&quot;background-color: rgb(255, 217, 102);&quot;&gt;Notify_lock-&amp;gt;notify();&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: rgb(255, 217, 102);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: rgb(255, 217, 102);&quot;&gt;&lt;div&gt;&amp;nbsp;// Wait for VM_Operations until termination&lt;/div&gt;&lt;div&gt;&amp;nbsp; &lt;b&gt;this-&amp;gt;loop();&lt;/b&gt;&lt;/div&gt;&lt;/span&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;fontSize=14;align=left;strokeWidth=1;fontStyle=0;" parent="xhyheTG0EHDTFoFn0KrG-57" vertex="1">
