        <mxCell id="o_nN2yiWmDkzXpWWsuQ8-1" value="&lt;div&gt;&amp;nbsp;oop thread_object = create_initial_thread(thread_group, main_thread, CHECK);&lt;/div&gt;&lt;div&gt;&amp;nbsp; main_thread-&amp;gt;set_threadObj(thread_object);&lt;/div&gt;&lt;div&gt;&amp;nbsp; // Set thread status to running since main thread has&lt;/div&gt;&lt;div&gt;&amp;nbsp; // been started and running.&lt;/div&gt;&lt;div&gt;&amp;nbsp; java_lang_Thread::set_thread_status(thread_object,&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; java_lang_Thread::&lt;span style=&quot;background-color: rgb(255, 204, 255);&quot;&gt;RUNNABLE&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;调用jvm.cpp#JVM_StartThread()初始化Java层面线程，Reference、&lt;/div&gt;&lt;span style=&quot;font-size: 14px; text-align: center;&quot;&gt;Finalizer、Signal Dispather、Common-Cleaner...&lt;/span&gt;" style="whiteSpace=wrap;html=1;labelBackgroundColor=none;fontSize=15;fontColor=none;strokeWidth=1;fillColor=default;align=left;" parent="o_nN2yiWmDkzXpWWsuQ8-5" vertex="1">
