        <mxCell id="o_nN2yiWmDkzXpWWsuQ8-9" value="&lt;div&gt;&amp;nbsp;Handle thread_oop(Thread::current(),&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; JNIHandles::resolve_non_null(jni_thread));&lt;/div&gt;&lt;div&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; set_threadObj(thread_oop());&lt;/div&gt;&lt;div&gt;&amp;nbsp; java_lang_Thread::set_thread(thread_oop(), this);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; if (prio == NoPriority) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; prio = java_lang_Thread::priority(thread_oop());&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; assert(prio != NoPriority, &quot;A valid priority should be present&quot;);&lt;/div&gt;&lt;div&gt;&amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; // Push the Java priority down to the native thread; needs Threads_lock&lt;/div&gt;&lt;div&gt;&amp;nbsp; Thread::set_priority(this, prio);&lt;/div&gt;" style="whiteSpace=wrap;html=1;labelBackgroundColor=none;fontSize=15;fontColor=none;strokeWidth=1;fillColor=default;align=left;" parent="o_nN2yiWmDkzXpWWsuQ8-11" vertex="1">
