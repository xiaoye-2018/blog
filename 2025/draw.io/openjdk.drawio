        <mxCell id="o_nN2yiWmDkzXpWWsuQ8-7" value="JavaThread *native_thread = NULL;&lt;br&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; MutexLocker mu(Threads_lock);&lt;/div&gt;&lt;div&gt;if (java_lang_Thread::thread(JNIHandles::resolve_non_null(jthread)) != NULL) {} else{&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div&gt;jlong size =&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;java_lang_Thread::stackSize(JNIHandles::resolve_non_null(jthread));&lt;/div&gt;&lt;div&gt;native_thread = &lt;span style=&quot;background-color: rgb(204, 229, 255);&quot;&gt;new JavaThread(&amp;amp;thread_entry, sz)&lt;/span&gt;;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&amp;nbsp;if (native_thread-&amp;gt;osthread() != NULL) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; // Note: the current thread is not being used within &quot;prepare&quot;.&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; native_thread-&amp;gt;&lt;span style=&quot;background-color: rgb(255, 204, 204);&quot;&gt;prepare&lt;/span&gt;(jthread);&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;.....&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: rgb(255, 204, 204);&quot;&gt;Thread::start(native_thread)&lt;/span&gt;;&lt;br&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;labelBackgroundColor=none;fontSize=15;fontColor=none;strokeWidth=1;fillColor=default;align=left;" parent="o_nN2yiWmDkzXpWWsuQ8-15" vertex="1">
