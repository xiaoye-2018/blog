n style=&quot;background-color: rgb(154, 199, 191);&quot;&gt;vm_thread&lt;/span&gt;();&lt;/div&gt;&lt;div style=&quot;background-color: initial;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;if (!os::create_thread(&lt;/span&gt;&lt;span style=&quot;background-color: rgb(154, 199, 191);&quot;&gt;vmthread&lt;/span&gt;, os::vm_thread)) {}&lt;/div&gt;&lt;div style=&quot;background-color: initial;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;div style=&quot;background-color: initial;&quot;&gt;MutexLocker ml(Notify_lock);&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: rgb(204, 204, 255);&quot;&gt;os::start_thread(vmthread);&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;background-color: initial;&quot;&gt;while (vmthread-&amp;gt;active_handles() == NULL) {&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: initial;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;background-color: rgb(255, 217, 102);&quot;&gt;&amp;nbsp; Notify_lock-&amp;gt;wait();&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;background-color: initial;&quot;&gt;} 。。。&lt;/div&gt;&lt;div style=&quot;background-color: initial;&quot;&gt;// 初始化main_thread， 内部会创建对应Java层面的线程oop&lt;/div&gt;&lt;div style=&quot;background-color: initial;&quot;&gt;initialize_java_lang_classes(main_thread, CHECK_JNI_ERR);&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;labelBackgroundColor=none;fontSize=14;fontColor=#000000;strokeWidth=1;fillColor=default;align=left;" parent="AzXcmR2tEOwElh5XjwPl-3" vertex="1">
