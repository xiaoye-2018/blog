        <mxCell id="xhyheTG0EHDTFoFn0KrG-5" value="&lt;span style=&quot;background-color: rgb(255, 204, 255);&quot;&gt;OSThread* osthread = new OSThread(NULL, NULL);&lt;/span&gt;&lt;br&gt;&lt;div&gt;// set the correct thread state&lt;/div&gt;&lt;div&gt;osthread-&amp;gt;set_thread_type(thr_type);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;// Initial state is ALLOCATED but not INITIALIZED&lt;/div&gt;&lt;div&gt;osthread-&amp;gt;set_state(&lt;span style=&quot;background-color: rgb(255, 204, 255);&quot;&gt;ALLOCATED&lt;/span&gt;);&lt;/div&gt;&lt;div&gt;&amp;nbsp;&lt;span style=&quot;background-color: rgb(154, 199, 191);&quot;&gt;thread&lt;/span&gt;-&amp;gt;&lt;span style=&quot;background-color: rgb(255, 204, 255);&quot;&gt;set_osthread&lt;/span&gt;(osthread);&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;pthread_t tid;&lt;/div&gt;&lt;div&gt;int ret = &lt;span style=&quot;background-color: rgb(255, 204, 255);&quot;&gt;pthread_create&lt;/span&gt;(&amp;amp;tid, &amp;amp;attr, (void* (*)(void*)) &lt;span style=&quot;background-color: rgb(255, 204, 255);&quot;&gt;thread_native_entry&lt;/span&gt;, &lt;span style=&quot;background-color: rgb(154, 199, 191);&quot;&gt;thread&lt;/span&gt;);&lt;/div&gt;&lt;/div&gt;&lt;div&gt;osthread-&amp;gt;set_pthread_id(tid);&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;while ((state = osthread-&amp;gt;get_state()) == ALLOCATED) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; sync_with_child-&amp;gt;&lt;span style=&quot;background-color: rgb(255, 230, 204);&quot;&gt;wait&lt;/span&gt;(Mutex::_no_safepoint_check_flag);&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;" style="whiteSpace=wrap;html=1;fontSize=14;strokeWidth=1;align=left;" parent="xhyheTG0EHDTFoFn0KrG-9" vertex="1">
