        <mxCell id="3VROzXJLyCU2EH3eLXKl-1" value="&lt;pre style=&quot;background-color: #e8e8e8 ; color: #222222 ; font-family: &amp;#34;jetbrains mono&amp;#34; , monospace ; font-size: 10.5pt&quot;&gt;&lt;br&gt;&lt;/pre&gt;&lt;pre style=&quot;background-color: #e8e8e8 ; color: #222222 ; font-family: &amp;#34;jetbrains mono&amp;#34; , monospace ; font-size: 10.5pt&quot;&gt;&lt;span style=&quot;color: #961574 ; font-weight: bold&quot;&gt;// 之前是否已经添加到三级缓存，boot 2.6 后，默认关闭&lt;/span&gt;&lt;/pre&gt;&lt;pre style=&quot;background-color: #e8e8e8 ; color: #222222 ; font-family: &amp;#34;jetbrains mono&amp;#34; , monospace ; font-size: 10.5pt&quot;&gt;&lt;span style=&quot;color: #961574 ; font-weight: bold&quot;&gt;if &lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #213b75 ; font-weight: bold&quot;&gt;earlySingletonExposure&lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;) {&lt;/span&gt;&lt;/pre&gt;&lt;pre style=&quot;background-color: #e8e8e8 ; color: #222222 ; font-family: &amp;#34;jetbrains mono&amp;#34; , monospace ; font-size: 10.5pt&quot;&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;   // 从二级缓存中获取对象，如果能够获取，说明出现循环依赖，其他bean存入， 不一定是代理对象&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;   &lt;/span&gt;&lt;span style=&quot;color: #08225c ; font-weight: bold&quot;&gt;Object &lt;/span&gt;&lt;span style=&quot;color: #213b75 ; font-weight: bold&quot;&gt;earlySingletonReference &lt;/span&gt;&lt;span style=&quot;color: #111111&quot;&gt;= &lt;/span&gt;&lt;span style=&quot;color: #08225c ; font-weight: bold&quot;&gt;getSingleton&lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #003300&quot;&gt;beanName&lt;/span&gt;&lt;span style=&quot;color: #111111&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #961574 ; font-weight: bold&quot;&gt;false&lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;)&lt;/span&gt;&lt;span style=&quot;color: #111111&quot;&gt;;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color: #111111&quot;&gt;   &lt;/span&gt;&lt;span style=&quot;color: #961574 ; font-weight: bold&quot;&gt;if &lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #213b75 ; font-weight: bold&quot;&gt;earlySingletonReference &lt;/span&gt;&lt;span style=&quot;color: #111111&quot;&gt;!= &lt;/span&gt;&lt;span style=&quot;color: #961574 ; font-weight: bold&quot;&gt;null&lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;) {&lt;/span&gt;&lt;/pre&gt;&lt;pre style=&quot;background-color: #e8e8e8 ; color: #222222 ; font-family: &amp;#34;jetbrains mono&amp;#34; , monospace ; font-size: 10.5pt&quot;&gt;      // 通常情况下必须相等，除非postProcessor中重新new对象返回&lt;/pre&gt;&lt;pre style=&quot;background-color: #e8e8e8 ; color: #222222 ; font-family: &amp;#34;jetbrains mono&amp;#34; , monospace ; font-size: 10.5pt&quot;&gt;      // &lt;span style=&quot;font-size: 10.5pt ; white-space: normal&quot;&gt;earlySingletonReference 可能是代理对象 ，也可能是原对象&lt;/span&gt;&lt;/pre&gt;&lt;pre style=&quot;background-color: #e8e8e8 ; color: #222222 ; font-family: &amp;#34;jetbrains mono&amp;#34; , monospace ; font-size: 10.5pt&quot;&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;      &lt;/span&gt;&lt;span style=&quot;color: #961574 ; font-weight: bold&quot;&gt;if &lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #213b75 ; font-weight: bold&quot;&gt;exposedObject &lt;/span&gt;&lt;span style=&quot;color: #111111&quot;&gt;== &lt;/span&gt;&lt;span style=&quot;color: #213b75 ; font-weight: bold&quot;&gt;bean&lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;) {&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;         &lt;/span&gt;&lt;span style=&quot;color: #213b75 ; font-weight: bold&quot;&gt;exposedObject &lt;/span&gt;&lt;span style=&quot;color: #111111&quot;&gt;= &lt;/span&gt;&lt;span style=&quot;color: #213b75 ; font-weight: bold&quot;&gt;earlySingletonReference&lt;/span&gt;&lt;span style=&quot;color: #111111&quot;&gt;;&lt;br&gt;&lt;/span&gt;&lt;span style=&quot;color: #111111&quot;&gt;      &lt;/span&gt;&lt;span style=&quot;color: #9c1a00&quot;&gt;}&lt;/span&gt;&lt;/pre&gt;" style="whiteSpace=wrap;html=1;align=left;" parent="3VROzXJLyCU2EH3eLXKl-0" vertex="1">
